# Токен бота от @BotFather
BOT_TOKEN=your_bot_token_here

# ID группы (получить можно через @userinfobot в группе, или через API)
GROUP_ID=your_group_id_here

# ID владельца бота (ваш Telegram ID)
OWNER_ID=owner_id_here

# Дополнительные админы (через запятую, необязательно)
ADMIN_IDS=admin_id1,admin_id2
